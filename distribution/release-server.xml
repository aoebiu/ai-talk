<assembly xmlns="http://maven.apache.org/ASSEMBLY/2.2.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/ASSEMBLY/2.2.0 http://maven.apache.org/xsd/assembly-1.1.2.xsd">
    <id>release-server</id>

    <formats>
        <format>tar.gz</format>
        <format>zip</format>
    </formats>

    <includeBaseDirectory>true</includeBaseDirectory>
    <baseDirectory>dialoger-ai-server</baseDirectory>

    <fileSets>
        <!-- bin/ — shell scripts (executable) -->
        <fileSet>
            <directory>${project.basedir}/bin</directory>
            <outputDirectory>bin</outputDirectory>
            <fileMode>0755</fileMode>
            <includes>
                <include>*.sh</include>
            </includes>
        </fileSet>

        <!-- bin/ — Windows scripts -->
        <fileSet>
            <directory>${project.basedir}/bin</directory>
            <outputDirectory>bin</outputDirectory>
            <fileMode>0644</fileMode>
            <includes>
                <include>*.cmd</include>
            </includes>
        </fileSet>

        <!-- conf/ — configuration files -->
        <fileSet>
            <directory>${project.basedir}/conf</directory>
            <outputDirectory>conf</outputDirectory>
            <fileMode>0644</fileMode>
        </fileSet>

        <!-- LICENSE from project root -->
        <fileSet>
            <directory>${project.basedir}/..</directory>
            <outputDirectory>.</outputDirectory>
            <fileMode>0644</fileMode>
            <includes>
                <include>LICENSE</include>
            </includes>
        </fileSet>
    </fileSets>

    <!-- lib/ — Spring Boot executable fat-jar -->
    <dependencySets>
        <dependencySet>
            <outputDirectory>lib</outputDirectory>
            <includes>
                <include>info.mengnan:server</include>
            </includes>
            <outputFileNameMapping>dialoger-ai-server.jar</outputFileNameMapping>
        </dependencySet>
    </dependencySets>

</assembly>
